#!/usr/bin/env bash
# gitmas-gateway — local Gitmas Memory HTTP gateway (the door for HTTP-only
# agents such as Hermes: POST /memory/store, /memory/search, …).
#
# Usage:
#   gitmas-gateway run                # foreground
#   gitmas-gateway install            # start on login (launchd on macOS)
#   gitmas-gateway status
#   gitmas-gateway token              # print the bearer token (creates one)

set -euo pipefail

GITMAS_HOME="${GITMAS_HOME:-$HOME/.gitmas}"
SERVER="$GITMAS_HOME/memory-server/http_server.py"
VENV_PY="$GITMAS_HOME/memory-server/.venv/bin/python"
PY="${GITMAS_MCP_PYTHON:-$VENV_PY}"
[ -x "$PY" ] || PY="$(command -v python3)"
TOKEN_FILE="${GITMAS_HTTP_TOKEN_FILE:-$GITMAS_HOME/memory-server/http.token}"
PORT="${GITMAS_HTTP_PORT:-8765}"
LABEL="com.gitmas.memory-http"
PLIST="$HOME/Library/LaunchAgents/$LABEL.plist"

ensure_token() {
  if [ ! -f "$TOKEN_FILE" ]; then
    "$PY" "$SERVER" --init-token --token-file "$TOKEN_FILE" >/dev/null
  fi
}

case "${1:-run}" in
  run)
    ensure_token
    exec "$PY" "$SERVER" --port "$PORT" --token-file "$TOKEN_FILE"
    ;;
  install)
    ensure_token
    if [ "$(uname)" = "Darwin" ]; then
      mkdir -p "$HOME/Library/LaunchAgents" "$GITMAS_HOME/logs"
      cat > "$PLIST" <<PLIST_EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0"><dict>
  <key>Label</key><string>$LABEL</string>
  <key>ProgramArguments</key><array>
    <string>$PY</string>
    <string>$SERVER</string>
    <string>--port</string><string>$PORT</string>
    <string>--token-file</string><string>$TOKEN_FILE</string>
  </array>
  <key>RunAtLoad</key><true/>
  <key>KeepAlive</key><true/>
  <key>StandardOutPath</key><string>$GITMAS_HOME/logs/memory-http.log</string>
  <key>StandardErrorPath</key><string>$GITMAS_HOME/logs/memory-http.err</string>
</dict></plist>
PLIST_EOF
      launchctl bootout "gui/$(id -u)" "$PLIST" >/dev/null 2>&1 || true
      launchctl bootstrap "gui/$(id -u)" "$PLIST" 2>/dev/null || launchctl kickstart -k "gui/$(id -u)/$LABEL" >/dev/null 2>&1 || true
      echo "gateway installed: http://127.0.0.1:$PORT (label $LABEL)"
    else
      nohup "$PY" "$SERVER" --port "$PORT" --token-file "$TOKEN_FILE" \
        >> "$GITMAS_HOME/logs/memory-http.log" 2>&1 &
      echo "gateway started in background: http://127.0.0.1:$PORT"
    fi
    echo "bearer token: $TOKEN_FILE"
    ;;
  status)
    curl -fsS -m 3 "http://127.0.0.1:$PORT/health" && echo || { echo "gateway not responding on :$PORT" >&2; exit 1; }
    ;;
  token)
    ensure_token
    cat "$TOKEN_FILE"
    ;;
  *)
    echo "usage: gitmas-gateway [run|install|status|token]" >&2
    exit 2
    ;;
esac
