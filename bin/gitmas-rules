#!/usr/bin/env bash
# gitmas-rules — the always-inject rules layer of Gitmas Memory.
#
# Hard rules must not depend on on-demand recall: rules are memories tagged
# "rule" (synced across devices like any memory), and this tool materializes
# them into the files agents read at EVERY session start:
#
#   ~/.gitmas/RULES.md            rendered rules (source of the block below)
#   ~/.claude/CLAUDE.md           gets one `@~/.gitmas/RULES.md` import line
#   ~/.codex/AGENTS.md            managed GITMAS-RULES block
#   ~/.hermes/SOUL.md             managed GITMAS-RULES block
#
# Usage:
#   gitmas-rules add "rule text"   store a new rule + apply everywhere
#   gitmas-rules apply             re-render and update all agent files
#   gitmas-rules render            print the rules block
#   gitmas-rules list              list rules with ids

set -euo pipefail

GITMAS_HOME="${GITMAS_HOME:-$HOME/.gitmas}"
DB="${GITMAS_DB_PATH:-${MEMORY_DB_PATH:-$GITMAS_HOME/memory/unified.db}}"
RULES_MD="$GITMAS_HOME/RULES.md"
BEGIN_MARK="<!-- GITMAS-RULES:BEGIN -->"
END_MARK="<!-- GITMAS-RULES:END -->"

rules_rows() {
  [ -f "$DB" ] || return 0
  sqlite3 -separator $'\t' "$DB" \
    "SELECT id, COALESCE(NULLIF(description,''), substr(replace(content, char(10), ' '), 1, 200))
     FROM memories
     WHERE tags LIKE '%\"rule\"%'
     ORDER BY created ASC;" 2>/dev/null
}

render() {
  printf '%s\n' "$BEGIN_MARK"
  printf '# Gitmas Rules – always apply\n'
  printf '<!-- auto-generated by gitmas-rules; add rules with: gitmas-rules add "..." -->\n'
  local any=0
  while IFS=$'\t' read -r id desc; do
    [ -z "${id:-}" ] && continue
    printf -- '- %s\n' "$desc"
    any=1
  done < <(rules_rows)
  [ "$any" -eq 0 ] && printf -- '- (no rules yet – add one with: gitmas-rules add "...")\n'
  printf '%s\n' "$END_MARK"
}

# Replace (or append) the managed block inside a file.
apply_block() {
  local target="$1"
  [ -f "$target" ] || return 0
  local real
  real="$(readlink "$target" 2>/dev/null || true)"
  [ -n "$real" ] && target="$real"
  RULES_BLOCK="$(render)" TARGET="$target" BEGIN="$BEGIN_MARK" END="$END_MARK" python3 - <<'PY'
import os
target = os.environ["TARGET"]
block = os.environ["RULES_BLOCK"]
begin, end = os.environ["BEGIN"], os.environ["END"]
s = open(target, encoding="utf-8").read()
if begin in s and end in s:
    pre = s.split(begin)[0]
    post = s.split(end, 1)[1]
    out = pre + block + post
else:
    out = s.rstrip("\n") + "\n\n" + block + "\n"
if out != s:
    open(target, "w", encoding="utf-8").write(out)
    print(f"  updated {target}")
PY
}

ensure_claude_import() {
  local claude_md="$HOME/.claude/CLAUDE.md"
  local import_line='@~/.gitmas/RULES.md'
  if [ ! -f "$claude_md" ]; then
    mkdir -p "$HOME/.claude"
    printf '# CLAUDE.md\n\n%s\n' "$import_line" > "$claude_md"
    echo "  created $claude_md with rules import"
    return
  fi
  local real
  real="$(readlink "$claude_md" 2>/dev/null || true)"
  [ -n "$real" ] && claude_md="$real"
  if ! grep -qF "$import_line" "$claude_md"; then
    printf '\n%s\n' "$import_line" >> "$claude_md"
    echo "  import line added to $claude_md"
  fi
}

apply() {
  mkdir -p "$GITMAS_HOME"
  render > "$RULES_MD"
  echo "rendered $RULES_MD"
  ensure_claude_import
  apply_block "$HOME/.codex/AGENTS.md"
  apply_block "$HOME/.hermes/SOUL.md"
}

case "${1:-apply}" in
  render) render ;;
  list)
    rules_rows | awk -F'\t' '{printf "%s  %s\n", substr($1,1,8), $2}'
    ;;
  add)
    shift
    TEXT="${1:?rule text required}"
    PY_BIN="${GITMAS_MCP_PYTHON:-$GITMAS_HOME/memory-server/.venv/bin/python}"
    [ -x "$PY_BIN" ] || PY_BIN="$(command -v python3)"
    RULE_TEXT="$TEXT" GITMAS_HOME="$GITMAS_HOME" "$PY_BIN" - <<'PY'
import os, sys
sys.path.insert(0, os.path.expanduser(os.path.join(os.environ["GITMAS_HOME"], "memory")))
sys.path.insert(0, os.path.expanduser("~/gitmas-config/memory"))
from unified_memory import UnifiedMemory
text = os.environ["RULE_TEXT"]
mem = UnifiedMemory()
mid = mem.store(text, text[:200], "feedback", tags=["rule"], scope="global")
print(f"  stored rule [{mid[:8]}]")
PY
    "$0" apply
    ;;
  apply) apply ;;
  *) echo "usage: gitmas-rules [add \"text\"|apply|render|list]" >&2; exit 2 ;;
esac
